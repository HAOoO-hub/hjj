// ========================
// 综合功能展示样例 2
// 重点展示：递归调用（阶乘）
// ========================

// 1. 递归函数：阶乘计算
int factorial(int n) {
    // 2. 递归终止条件
    if (n == 0 || n == 1) {
        return 1;
    }
    // 3. 递归调用
    return n * factorial(n - 1);
}

int main() {
    // 4. 常量声明
    const int LIMIT = 100;
    
    // 5. 变量声明
    int n;
    int result;
    int total;
    
    // 6. 赋值语句
    n = 5;
    
    // 7. 递归调用：计算阶乘
    result = factorial(n);
    
    // 8. 在条件中使用递归结果
    if (result > LIMIT) {
        total = result - 10;
    } else {
        total = result;
    }
    
    // 9. 再次调用阶乘
    n = 4;
    result = factorial(n);
    
    // 10. 最终计算
    total = total + result;
    
    return 0;
}
