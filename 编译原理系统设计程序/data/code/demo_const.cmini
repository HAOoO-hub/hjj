// ========================
// 常量表功能测试样例
// 展示 const 关键字的使用
// ========================

int main() {
    // 1. 常量声明（必须初始化）
    const int MAX = 100;
    const int MIN = 0;
    
    // 2. 普通变量声明
    int x;
    int y = 50;
    
    // 3. 使用常量进行计算
    x = MAX + MIN;
    y = MAX - 10;
    
    // 4. 在条件中使用常量
    if (x > MAX) {
        x = MAX;
    }
    
    // 5. 在循环中使用常量
    while (y < MAX) {
        y = y + 1;
    }
    
    return 0;
}
