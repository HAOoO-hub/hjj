// ========================
// I/O 功能测试样例 3 - 循环中的输入输出
// ========================

int main() {
    int n;
    int i;
    int sum;
    
    // 读取循环次数
    read n;
    
    // 初始化
    i = 1;
    sum = 0;
    
    // 累加 1 到 n
    while (i <= n) {
        sum = sum + i;
        i = i + 1;
    }
    
    // 输出结果
    write sum;
    
    return 0;
}
