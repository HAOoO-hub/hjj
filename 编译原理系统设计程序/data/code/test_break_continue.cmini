// ========================
// Break 和 Continue 功能测试
// ========================

int main() {
    int i;
    int sum;
    int count;
    
    // 测试1: break - 求和直到超过某个值
    i = 1;
    sum = 0;
    
    while (i <= 10) {
        sum = sum + i;
        
        // 如果和超过20，跳出循环
        if (sum > 20) {
            break;
        }
        
        i = i + 1;
    }
    
    // 此时 sum 应该是 1+2+3+4+5+6 = 21, i = 6
    
    // 测试2: continue - 跳过偶数，只累加奇数
    i = 1;
    count = 0;
    sum = 0;
    
    while (i <= 10) {
        // 如果是偶数，跳过
        if (i == 2 || i == 4 || i == 6 || i == 8 || i == 10) {
            i = i + 1;
            continue;
        }
        
        sum = sum + i;
        count = count + 1;
        i = i + 1;
    }
    
    // 此时 sum 应该是 1+3+5+7+9 = 25, count = 5
    
    return 0;
}
